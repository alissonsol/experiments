# All files and folders starting with "."
.*
._*

# Keep the gitignore itself
!.gitignore

# JavaScript / Node.js
node_modules/
dist/
out/
build/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
*.min.js
*.map

# VS Code extension packaging
*.vsix

# Logs and temp files
logs/
*.log
*.tmp
